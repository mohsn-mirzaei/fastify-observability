{
  "id": null,
  "uid": "fastify-loki-logs",
  "title": "Fastify Logs",
  "tags": ["loki", "logs"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "level",
        "label": "level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({service=\"fastify-observability\"}, level)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Application Logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "{service=\"fastify-observability\", level=~\"$level\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Logs Rate by Level",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (level) (rate({service=\"fastify-observability\", level=~\"$level\"}[1m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Logs Rate",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate({service=\"fastify-observability\", level=~\"50|60\"}[1m]))",
          "refId": "A"
        }
      ]
    }
  ],
  "time": { "from": "now-15m", "to": "now" },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
